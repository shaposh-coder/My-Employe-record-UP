# Copy this file to .env.local and fill in values from your Supabase project:
# Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — Settings → API → service_role (never commit real values). Required to create
# login + password when adding users from Settings.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
